# Public site URL — used for SEO meta, sitemap, OG image, robots.txt
# In Vercel, set this in the project's Environment Variables once the real
# domain is connected.
NEXT_PUBLIC_SITE_URL=https://pixwarp.app

# PostHog (free tier — 1M events / month) for behavioral analytics:
# tool_open / file_dropped / convert_success / convert_error fan out to both
# Vercel Web Analytics and PostHog.
# Leave NEXT_PUBLIC_POSTHOG_KEY empty to disable PostHog (Vercel-only).
# Grab the key at posthog.com → Project Settings → Project API Key.
# Host stays as /ingest so requests are proxied through this origin (see
# next.config.ts rewrites) — bypasses ad-blockers, works in CN.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/ingest
